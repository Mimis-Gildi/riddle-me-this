{
  automerge: true,
  extends: [
    'config:recommended',
  ],
  timezone: 'America/New_York',
  assignees: [
    'rdd13r',
  ],
  branchPrefix: 'renovate/',
  schedule: [
    'every weekday',
    'every weekend',
  ],
  labels: [
    'dependencies',
    'renovate',
  ],
  packageRules: [
    {
      description: 'Pin @actions/stale to v8.0.0',
      matchPackageNames: ['actions/stale'],
      rangeStrategy: 'pin',
      allowedVersions: '8.0.0'
    },
    {
      description: 'Aggressive grouping for Gradle root project',
      matchManagers: [
        'gradle'
      ],
      matchFileNames: [
        'build.gradle.kts',
        'gradle.properties'
      ],
      groupName: 'Gradle Root Updates',
      automerge: true
    },
    {
      description: 'Aggressive grouping for buildSrc',
      matchManagers: [
        'gradle'
      ],
      matchFileNames: [
        'buildSrc/**'
      ],
      groupName: 'Gradle BuildSrc Updates',
      automerge: true
    },
    {
      description: 'GitHub Actions Updates',
      matchManagers: [
        'github-actions'
      ],
      groupName: 'GitHub Actions Updates',
      automerge: true
    },
    {
      description: 'Pin Ruby to 3.3.5 (matches self-hosted runner)',
      matchManagers: [
        'asdf'
      ],
      matchPackageNames: [
        'ruby'
      ],
      allowedVersions: '3.3.5'
    },
    {
      description: 'Bundler / Jekyll Updates (monthly)',
      matchManagers: [
        'bundler'
      ],
      groupName: 'Bundler Updates',
      automerge: true,
      schedule: [
        'monthly'
      ]
    },
    {
      description: 'Pin actions/checkout below v6 — v6+ includeIf.gitdir auth breaks on symlinked _work (gen-1 runners); see actions/checkout#2321',
      matchPackageNames: ['actions/checkout'],
      allowedVersions: '<6',
    }
  ],
  dependencyDashboard: true,
  prHourlyLimit: 5,
  prConcurrentLimit: 10,
}
