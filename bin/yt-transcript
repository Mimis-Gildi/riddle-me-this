#!/usr/bin/env python
"""
yt-transcript — print a YouTube video's transcript to stdout.

WHY THIS EXISTS (read before you reinvent it):
  Bare scraping of YouTube captions is dead. The old
  `api/timedtext?v=ID&lang=en` URL is token-gated now — it returns 0 bytes
  for every format (json3/xml/srv3/vtt). yt-dlp/youtube-dl are asdf-plugin
  -added but NOT installed (no version, no shim). The working, no-install
  path is the `youtube_transcript_api` library in the 'ml' conda env — it
  gets the token the legitimate way. Hence, the hardcoded ml-env shebang.
  If you find yourself hand-rolling curl against timedtext: stop. Use this.

USAGE:
    bin/yt-transcript <url-or-id> [-l CODE[,CODE...]] [-t|--timestamps]
    bin/yt-transcript <url-or-id> --list # show available caption languages

  -l/--lang takes a priority list, e.g. `-l uk,en` (prefer Ukrainian, fall
  back to English). Omit it to take the library default. For a video whose
  audio is one language but whose only manual subtitle is a translation,
  use --list first to see what tracks actually exist (manual vs. generated).

EXAMPLES:
    bin/yt-transcript https://youtu.be/XGsA3wYP-wQ
    bin/yt-transcript 3FLN-5ErjO4 --list
    bin/yt-transcript 3FLN-5ErjO4 -l uk -t > /tmp/transcript.txt
"""
import re
import sys


def video_id(s):
    s = s.strip()
    if re.fullmatch(r"[A-Za-z0-9_-]{11}", s):
        return s
    m = re.search(r"(?:v=|/shorts/|/live/|youtu\.be/|/embed/)([A-Za-z0-9_-]{11})", s)
    if m:
        return m.group(1)
    raise SystemExit(f"yt-transcript: no video id found in: {s!r}")


def list_langs(vid):
    from youtube_transcript_api import YouTubeTranscriptApi
    try:                                   # instance API (>= 1.0)
        tl = YouTubeTranscriptApi().list(vid)
    except AttributeError:                 # legacy (< 1.0)
        # noinspection PyUnresolvedReferences
        tl = YouTubeTranscriptApi.list_transcripts(vid)
    for t in tl:
        kind = "generated" if getattr(t, "is_generated", False) else "manual"
        print(f"{t.language_code}\t{kind}\t{t.language}")


def fetch(vid, langs):
    from youtube_transcript_api import YouTubeTranscriptApi
    errs = []
    try:                                   # instance API (>= 1.0)
        api = YouTubeTranscriptApi()
        f = api.fetch(vid, languages=langs) if langs else api.fetch(vid)
        return [(s.start, s.text) for s in f]
    except Exception as e:
        errs.append(f"fetch(): {e!r}")
    try:                                   # legacy static API (< 1.0)
        # noinspection PyUnresolvedReferences
        data = (YouTubeTranscriptApi.get_transcript(vid, languages=langs) if langs
                else YouTubeTranscriptApi.get_transcript(vid))
        return [(d["start"], d["text"]) for d in data]
    except Exception as e:
        errs.append(f"get_transcript(): {e!r}")
    raise SystemExit("yt-transcript: no transcript available.\n  " + "\n  ".join(errs))


def main(argv):
    langs = None
    ts = False
    do_list = False
    pos = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a in ("-t", "--timestamps"):
            ts = True
        elif a == "--list":
            do_list = True
        elif a in ("-l", "--lang"):
            i += 1
            if i >= len(argv):
                raise SystemExit("yt-transcript: -l/--lang needs a value, e.g. -l uk,en")
            langs = argv[i].split(",")
        elif a.startswith("--lang="):
            langs = a.split("=", 1)[1].split(",")
        elif a.startswith("-l") and len(a) > 2:
            langs = a[2:].split(",")
        elif a.startswith("-"):
            raise SystemExit(f"yt-transcript: unknown option {a!r}")
        else:
            pos.append(a)
        i += 1
    if len(pos) != 1:
        raise SystemExit("usage: yt-transcript <url-or-id> [-l CODE[,CODE...]] [-t] [--list]")
    vid = video_id(pos[0])
    if do_list:
        list_langs(vid)
        return
    for start, text in fetch(vid, langs):
        text = text.strip()
        if not text:
            continue
        print(f"[{int(start) // 60:02d}:{int(start) % 60:02d}] {text}" if ts else text)


if __name__ == "__main__":
    main(sys.argv[1:])
